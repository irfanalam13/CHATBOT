# ── Application ────────────────────────────────────────────────
APP_NAME="Enterprise AI Chatbot Platform"
ENVIRONMENT=development          # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-long-random-string
# Used to encrypt sensitive columns (tenant API keys, etc). 32-byte urlsafe base64.
ENCRYPTION_KEY=change-me-fernet-key

# ── CORS ───────────────────────────────────────────────────────
# Frontend origins allowed to call the API in production (DEBUG=false).
# Comma-separated, no trailing slash. Ignored in DEBUG mode (all allowed).
# CORS_ORIGINS=https://your-frontend-domain.com,https://app.example.com

# ── JWT ────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot
POSTGRES_DB=chatbot
# Override the whole URL if you prefer:
# DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Qdrant ─────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Object storage (S3 compatible: AWS S3 / MinIO) ─────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=chatbot-documents
S3_REGION=us-east-1

# ── LLM providers ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-opus-4-8

# ── Embeddings ─────────────────────────────────────────────────
DEFAULT_EMBEDDING_PROVIDER=openai          # openai | google | bge | e5 | instructor
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── RAG ────────────────────────────────────────────────────────
DEFAULT_CHUNK_STRATEGY=recursive
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=8
RERANK_TOP_N=4
ENABLE_RERANKING=true

# ── Rate limiting ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ── Observability ──────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_JSON=true
