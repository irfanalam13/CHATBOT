# Backend base URL (used by next.config rewrites for /api proxying).
BACKEND_URL=http://localhost:8000

# Public WebSocket origin for the chat WS endpoint (browser-side).
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Default tenant slug for the login screen (white-label deployments pin one).
NEXT_PUBLIC_DEFAULT_TENANT=demo
NEXT_PUBLIC_APP_NAME="Enterprise AI Assistant"
